source ~/.vim/vim-plug-settings.vim

set termguicolors

colorscheme nord
highlight Normal guibg=NONE ctermbg=NONE
highlight NonText guifg=#6e7681 ctermfg=grey
highlight EndOfBuffer guifg=#6e7681 ctermfg=grey

set number
set shiftwidth=4
set softtabstop=4
set expandtab
set smarttab
autocmd FileType yaml setlocal shiftwidth=2 softtabstop=2 expandtab smarttab
autocmd FileType sh setlocal shiftwidth=4 softtabstop=4 expandtab smarttab
