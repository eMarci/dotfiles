shopt -s nullglob globstar histappend checkwinsize

# If not running interactively, don't do anything
if [[ $- != *i* ]]; then
    return
fi

# Don't put duplicate lines or lines starting with space in the history.
# See bash(1) for more options
HISTCONTROL=ignoreboth

# For setting history length see HISTSIZE and HISTFILESIZE in bash(1)
HISTSIZE=1000
HISTFILESIZE=2000

# Make less more friendly for non-text input files, see lesspipe(1)
[[ -x /usr/bin/lesspipe ]] && eval "$(SHELL=/bin/sh lesspipe)"

# Load aliases
if [[ -f ~/.bash_aliases ]]; then
    . ~/.bash_aliases
fi

# Enable programmable completion features (you don't need to enable
# this, if it's already enabled in /etc/bash.bashrc and /etc/profile
# sources /etc/bash.bashrc).
if ! shopt -oq posix; then
    if [[ -f /usr/share/bash-completion/bash_completion ]]; then
        . /usr/share/bash-completion/bash_completion
    elif [[ -f /etc/bash_completion ]]; then
        . /etc/bash_completion
    fi
fi

# Run any local startup scripts
if [[ -d ~/.bashrc.d ]]; then
    for F in ~/.bashrc.d/*; do
        [[ -x $F ]] && "$F"
    done
fi

# Source any function declarations
if [[ -d ~/.functions ]]; then
    for F in ~/.functions/*; do
        [[ -r $F ]] && source "$F"
    done
fi

# ==== Exports ====
export EDITOR='vim'
export VISUAL='vim'
export PAGER='less --use-color -R'
# ================

# Configure bat
eval "$(~/.local/bin/bat --completion bash)"

# Configure chezmoi
eval "$(~/.local/bin/chezmoi completion bash)"

# Configure rg
eval "$(~/.local/bin/rg --generate=complete-bash)"

# Configure fzf
export FZF_DEFAULT_COMMAND='rg --files --hidden --glob "!.git" --no-ignore-vcs'

export FZF_CTRL_T_COMMAND="$FZF_DEFAULT_COMMAND"
export FZF_CTRL_T_OPTS="
    --walker-skip .git,node_modules,target
    --preview 'bat -n --color=always {}'"

export FZF_ALT_C_COMMAND='fd --type d --hidden'

eval "$(~/.local/bin/fzf --bash)"

# Configure keychain
eval "$(~/.local/bin/keychain --eval ~/.ssh/identities/**/*.key)"

# Start starship
eval "$(~/.local/bin/starship init bash)"
eval "$(~/.local/bin/starship completions bash)"

# Configure GitHub CLI
eval "$(~/.local/bin/gh completion -s bash)"
